document.getElementById('search').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  function clearSearch(n) { n._collapsed = true; n._searchMatch = false; (n.children||[]).forEach(c => clearSearch(c)); }
  clearSearch(D.tree);
  if (!q) { D.tree._collapsed = false; searchActive = false; render(true); return; }
  searchActive = true;
  function markMatches(n) {
    const selfMatch = n.name.toLowerCase().includes(q) || (n.urls||[]).some(u=>u.url.toLowerCase().includes(q));
    if (selfMatch) n._searchMatch = true;
    let childMatch = false;
    if (n.children) n.children.forEach(c => { if(markMatches(c)) childMatch = true; });
    if (childMatch) { n._collapsed = false; n._searchMatch = true; }
    if (selfMatch && n._hasChildren) n._collapsed = false;
    return selfMatch || childMatch;
  }
  markMatches(D.tree);
  D.tree._collapsed = false;
  render(true);
