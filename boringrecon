    if (n._hasChildren) {
      const ind = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      ind.setAttribute('class', 'indicator');
      ind.setAttribute('x', -14);
      ind.setAttribute('y', 4);
      ind.style.cursor = 'pointer';
      ind.textContent = n._collapsed ? '▶' : '▼';
      ind.addEventListener('click', (e) => {
        e.stopPropagation();
        n._collapsed = !n._collapsed;
        render(true);
        selectNode(n);
      });
      ng.appendChild(ind);
    }

    const r = n._hasChildren ? 8 : 5;
    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('r', r);
    ng.appendChild(circle);

    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', r + 6);
    text.setAttribute('y', 4);
    let label = n._depth === 0 ? n.name : '/' + n.name;
    if (label.length > 28) label = label.slice(0, 26) + '..';
    text.textContent = label;
    ng.appendChild(text);

    const title = document.createElementNS('http://www.w3.org/2000/svg', 'title');
    title.textContent = n._depth === 0 ? n.name : '/' + n.path;
    ng.appendChild(title);

    if (n._hasChildren) {
      const cnt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      cnt.setAttribute('class', 'count');
      cnt.setAttribute('x', r + 6 + label.length * 6.5 + 4);
      cnt.setAttribute('y', 4);
      const total = countAll(n);
      cnt.textContent = n._collapsed ? `(+${total})` : `(${total})`;
      ng.appendChild(cnt);
    }

    let didDrag = false;
    ng.addEventListener('click', (e) => {
      e.stopPropagation();
      if (didDrag) { didDrag = false; return; }
      selectNode(n);
    });
    ng.addEventListener('dblclick', (e) => {
      e.stopPropagation();
      if (n._hasChildren) {
        n._collapsed = !n._collapsed;
        render(true);
      }
    });

    // Drag support
    let dragStart = null, origX, origY;
    ng.addEventListener('mousedown', (e) => {
      if (e.button !== 0) return;
      e.stopPropagation();
      didDrag = false;
      dragStart = { x: e.clientX, y: e.clientY };
      origX = n._x; origY = n._y;
      const onMove = (me) => {
        const dx = me.clientX - dragStart.x, dy = me.clientY - dragStart.y;
        if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
        n._x = origX + dx / transform.k;
        n._y = origY + dy / transform.k;
        ng.setAttribute('transform', `translate(${n._x},${n._y})`);
        updateLinks();
      };
      const onUp = () => {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });

    nodeEls[n._id] = ng;
    g.appendChild(ng);
  });

  if (animate && Object.keys(oldPos).length) {
    allNodes.forEach(n => {
      const p = oldPos[n._id] || (n._parent ? (oldPos[n._parent._id] || targetPos[n._parent._id]) : targetPos[n._id]);
      n._x = p.x; n._y = p.y;
    });
    positionAll();
    const start = performance.now();
    function step(now) {
      let t = Math.min(1, (now - start) / 300);
      t = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
      allNodes.forEach(n => {
        const o = oldPos[n._id] || (n._parent ? (oldPos[n._parent._id] || targetPos[n._parent._id]) : targetPos[n._id]);
        const tgt = targetPos[n._id];
        n._x = o.x + (tgt.x - o.x) * t;
        n._y = o.y + (tgt.y - o.y) * t;
      });
      positionAll();
      if (t < 1) animFrame = requestAnimationFrame(step);
      else animFrame = null;
    }
    animFrame = requestAnimationFrame(step);
  } else {
    positionAll();
  }

  applyTransform();
}

function countAll(n) {
  let c = (n.urls || []).length;
  if (n.children) n.children.forEach(ch => c += countAll(ch));
  return c;
}

function positionAll() {
  allNodes.forEach(n => {
    const el = nodeEls[n._id];
    if (el) el.setAttribute('transform', `translate(${n._x},${n._y})`);
  });
  linkEls.forEach(l => {
    const mx = (l.source._x + l.target._x) / 2;
    l.path.setAttribute('d', `M${l.source._x},${l.source._y} C${mx},${l.source._y} ${mx},${l.target._y} ${l.target._x},${l.target._y}`);
  });
}

function updateLinks() {
  linkEls.forEach(l => {
    const mx = (l.source._x + l.target._x) / 2;
    l.path.setAttribute('d', `M${l.source._x},${l.source._y} C${mx},${l.source._y} ${mx},${l.target._y} ${l.target._x},${l.target._y}`);
  });
}

function highlightPath(n) {
  const pathIds = new Set();
  let cur = n;
  while (cur) { pathIds.add(cur._id); cur = cur._parent; }
  linkEls.forEach(l => {
    if (pathIds.has(l.source._id) && pathIds.has(l.target._id)) l.path.classList.add('highlight');
    else l.path.classList.remove('highlight');
  });
}

// Side panel
function selectNode(n) {
  selectedNode = n;
  const panel = document.getElementById('panel');
  const title = document.getElementById('panel-title');
  const content = document.getElementById('panel-content');
  panel.classList.add('show');

  const fullPath = n._depth === 0 ? n.name : D.target + '/' + n.path;
  title.textContent = n._depth === 0 ? n.name : '/' + n.path;

  let html = '';

  // Per-host tech stack & title (host nodes or root in single-host mode)
  const hostKey = n._depth === 0 ? (D.httpx[0]||{}).url : n.path;
  const hi = hostKey ? hostInfo[(() => { try { return new URL(hostKey).hostname; } catch(e) { return hostKey; } })()] : null;
  if (hi) {
    if (hi.title) html += `<div style="color:#64748b;margin-bottom:8px">${hi.title}</div>`;
    if (hi.tech) {
      html += '<h3>Tech Stack</h3>';
      html += hi.tech.split(',').map(t => `<span class="chip">${t.trim()}</span>`).join(' ');
    }
  }

  // Subdomain takeover
  const toHost = (() => { try { return new URL(hostKey).hostname; } catch(e) { return (hostKey||'').toLowerCase(); } })();
  if (D.takeovers[toHost]) html += `<div class="takeover-alert">VULNERABLE — Subdomain Takeover</div>`;

  // Vulns scoped to this host/path
  const nodeVulns = D.vulns.filter(v => {
    if (n._depth === 0) return true;
    try { const vh = new URL(v.url).hostname; return n.path === vh || v.url.includes('/' + n.path); } catch(e) { return v.url.includes('/' + n.path); }
  });
  if (nodeVulns.length) {
    html += '<h3>Vulnerabilities</h3>';
    nodeVulns.forEach(v => {
      const s = (v.severity||'info').toLowerCase();
      html += `<div class="vuln-item"><span class="sev sev-${s}">${v.severity}</span> <b>${v.template}</b><br><a href="${v.url}" target="_blank">${v.url}</a></div>`;
    });
  }

  // Ports (root node)
  if (n._depth === 0 && Object.keys(D.ports).length) {
    html += '<h3>Open Ports</h3>';
    Object.entries(D.ports).forEach(([host, ps]) => {
      html += `<div style="margin-bottom:6px"><b>${host}</b><br>`;
      ps.forEach(p => { html += `<span class="port-chip">${p.port} ${p.service}</span>`; });
      html += '</div>';
    });
  }

  // URLs at this node
  const urls = n.urls || [];
  if (urls.length) {
    html += `<h3>URLs (${urls.length})</h3>`;
    urls.forEach(u => {
      const src = D.urlSources[u.url];
      html += `<div class="panel-url"><a href="${u.url}" target="_blank">${u.url}</a>`;
      if (src) html += `<span class="src-badge src-${src}">${src}</span>`;
      const pkeys = Object.keys(u.params||{});
      if (pkeys.length) html += ' ' + pkeys.map(p => `<span class="chip" style="background:#fef3c7;border-color:#fcd34d">${p}</span>`).join('');
      html += '</div>';
      const ssKey = urlToSsKey(u.url);
      if (D.screenshots[ssKey]) {
        html += `<img class="panel-screenshot" src="screenshots/${ssKey}" onclick="openLB(this.src,'${u.url.replace(/'/g,"\\'")}')" loading="lazy">`;
      }
    });
  }

  // Child screenshots (if this is a folder node)
  if (n.children && n.children.length) {
    const childUrls = [];
    function collectUrls(node) {
      (node.urls||[]).forEach(u => childUrls.push(u));
      (node.children||[]).forEach(c => collectUrls(c));
    }
    n.children.forEach(c => collectUrls(c));
    const withSS = childUrls.filter(u => D.screenshots[urlToSsKey(u.url)]);
    if (withSS.length) {
      html += `<h3>Screenshots (${withSS.length})</h3>`;
      withSS.slice(0, 20).forEach(u => {
        const ssKey = urlToSsKey(u.url);
        html += `<div class="panel-url"><a href="${u.url}" target="_blank">${u.url}</a></div>`;
        html += `<img class="panel-screenshot" src="screenshots/${ssKey}" onclick="openLB(this.src,'${u.url.replace(/'/g,"\\'")}')" loading="lazy">`;
      });
      if (withSS.length > 20) html += `<div style="color:#94a3b8;padding:4px">+${withSS.length-20} more...</div>`;
    }
  }

  // Params
  if (n._depth === 0 && D.paramNames.length) {
    html += '<h3>Parameters</h3>';
    D.paramNames.forEach(p => { html += `<span class="chip" style="background:#fef3c7;border-color:#fcd34d;margin:2px">${p}</span>`; });
  }

  // JS Files
  if (n._depth === 0 && D.jsFiles.length) {
    html += '<h3>JS Files</h3>';
    D.jsFiles.forEach(f => { html += `<div class="panel-url"><a href="${f}" target="_blank">${f}</a></div>`; });
  }

  if (!html) html = '<div style="color:#94a3b8;padding:12px">Click nodes to explore. Drag to rearrange.</div>';
  content.innerHTML = html;

  document.querySelectorAll('.node.selected').forEach(el => el.classList.remove('selected'));
  if (nodeEls[n._id]) nodeEls[n._id].classList.add('selected');
  highlightPath(n);
}

// Pan & zoom
function applyTransform() {
  const g = document.getElementById('zoom-group');
  if (g) g.setAttribute('transform', `translate(${transform.x},${transform.y}) scale(${transform.k})`);
}

function zoomBy(factor) {
  transform.k *= factor;
  transform.k = Math.max(0.15, Math.min(3, transform.k));
  applyTransform();
}

function resetView() {
  transform = { x: 40, y: H / 4, k: 0.9 };
  applyTransform();
}

// Pan with mouse drag on canvas
let panning = false, panStart;
wrap.addEventListener('mousedown', (e) => {
  if (e.target.closest('.node')) return;
  panning = true; panStart = { x: e.clientX - transform.x, y: e.clientY - transform.y };
  wrap.classList.add('grabbing');
});
document.addEventListener('mousemove', (e) => {
  if (!panning) return;
  transform.x = e.clientX - panStart.x;
  transform.y = e.clientY - panStart.y;
  applyTransform();
});
document.addEventListener('mouseup', () => { panning = false; wrap.classList.remove('grabbing'); });
wrap.addEventListener('wheel', (e) => {
  e.preventDefault();
  zoomBy(e.deltaY < 0 ? 1.1 : 0.9);
}, { passive: false });

function expandAll() {
  function ex(n) { n._collapsed = false; if(n.children) n.children.forEach(ex); }
  ex(D.tree); render(true);
}
function collapseAll() {
  function cl(n,d) { if(d>0) n._collapsed = true; if(n.children) n.children.forEach(c=>cl(c,d+1)); }
  cl(D.tree,0); render(true);
}

// Search
