// Convert tree data to nodes/links with positions
let allNodes = [], allLinks = [], nodeMap = {};
let nextId = 0;

function initNode(d, parent, depth) {
  d._id = nextId++;
  d._depth = depth;
  d._parent = parent;
  d._collapsed = depth > 1;
  d._x = 0; d._y = 0;
  d._hasChildren = d.children && d.children.length > 0;
  d._hasParam = (d.urls||[]).some(u => Object.keys(u.params||{}).length > 0);
  d._hasVuln = D.vulns.some(v => v.url.includes('/' + d.path));
  nodeMap[d._id] = d;
  if (d.children) d.children.forEach(c => initNode(c, d, depth + 1));
}
initNode(D.tree, null, 0);

function getVisible(node) {
  let nodes = [node];
  if (!node._collapsed && node.children) {
    node.children.forEach(c => { nodes = nodes.concat(getVisible(c)); });
  }
  return nodes;
}

function layoutSubtree(node, x, nextY) {
  const hSpacing = 200, vSpacing = 32;
  node._x = x;
  if (node._collapsed || !node.children || !node.children.length) {
    node._y = nextY;
    return nextY + vSpacing;
  }
  node.children.forEach(ch => {
    nextY = layoutSubtree(ch, x + hSpacing, nextY);
  });
  node._y = (node.children[0]._y + node.children[node.children.length - 1]._y) / 2;
  return nextY;
}

function layout() {
  allNodes = getVisible(D.tree);
  allLinks = [];
  layoutSubtree(D.tree, 60, 40);
  allNodes.forEach(n => {
    if (n._parent && allNodes.includes(n._parent)) {
      allLinks.push({ source: n._parent, target: n });
    }
  });
}

// SVG rendering
let svg, transform = { x: 0, y: 0, k: 1 };
let selectedNode = null;
let animFrame = null, nodeEls = {}, linkEls = [];

function render(animate) {
  if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
  const oldPos = {};
  allNodes.forEach(n => { oldPos[n._id] = { x: n._x, y: n._y }; });

  layout();

  const targetPos = {};
  allNodes.forEach(n => { targetPos[n._id] = { x: n._x, y: n._y }; });

  const svgEl = document.getElementById('canvas');
