        if u not in url_sources:
            url_sources[u] = label

def build_d3_tree(urls, target, alive_hosts):
    from collections import defaultdict
    root = {"name": target, "children": {}, "urls": [], "path": "/"}

    host_urls = defaultdict(list)
    for raw in urls:
        p = urlparse(raw)
        host_urls[f"{p.scheme}://{p.netloc}"].append(raw)
    for h in alive_hosts:
        if h and h not in host_urls:
            host_urls[h] = []

    def add_url(node, raw, path_prefix=""):
        parsed = urlparse(raw)
        path = parsed.path.strip("/")
        segs = path.split("/") if path else []
        cur = node
        for i, seg in enumerate(segs):
            cp = (path_prefix + "/" if path_prefix else "") + "/".join(segs[:i+1])
            if seg not in cur["children"]:
                cur["children"][seg] = {"name":seg, "children":{}, "urls":[], "path":cp}
            cur = cur["children"][seg]
        cur["urls"].append({"url":raw, "params":dict(parse_qs(parsed.query))})

    if len(host_urls) > 1:
        for hk in sorted(host_urls):
            netloc = urlparse(hk).netloc
            hn = {"name": hk, "children": {}, "urls": [], "path": netloc}
            for raw in host_urls[hk]:
                add_url(hn, raw, netloc)
            root["children"][hk] = hn
    else:
        for raw in urls:
            add_url(root, raw)

    def to_list(n):
        ch = sorted(n["children"].values(), key=lambda x: x["name"])
        return {"name":n["name"], "path":n["path"], "urls":n["urls"],
                "children":[to_list(c) for c in ch]}
    return to_list(root)

tree = build_d3_tree(endpoints, TARGET, read_lines(os.path.join(BASE, "subdomains/alive.txt")))

# Screenshots — just collect filenames, reference originals via relative path
