#!/bin/bash

# Colors
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
BOLD="\e[1m"
RESET="\e[0m"

banner() {
    echo -e "${CYAN}"
    echo "  ╔╗ ╔═╗╦═╗╦╔╗╔╔═╗"
    echo "  ╠╩╗║ ║╠╦╝║║║║║ ╦"
    echo "  ╚═╝╚═╝╩╚═╩╝╚╝╚═╝ recon"
    echo -e "${RESET}"
}

usage() {
    echo -e "${CYAN}boringrecon${RESET} — automated web recon with interactive report"
    echo
    echo -e "${BOLD}Usage:${RESET} boringrecon [options] <domain|URL>"
    echo
    echo -e "${BOLD}Options:${RESET}"
    echo "  -q               Quick mode (top-100 nmap, skip nuclei/vhosts)"
    echo "  -d               Deep mode (enable subfinder + amass subdomain enum)"
    echo "  -H <value|file>  Add custom HTTP header (repeatable)"
    echo "                     boringrecon -H 'Cookie: session=abc123' target"
    echo "                     boringrecon -H /path/to/headers.txt target"
    echo "  -h               Show this help"
    echo
    echo -e "${BOLD}Examples:${RESET}"
    echo "  boringrecon example.com              Standard scan on a domain"
    echo "  boringrecon -q http://10.10.11.5      Quick scan on an IP"
    echo "  boringrecon -d example.com            Deep scan with subdomain enum"
    echo "  boringrecon -H cookies.txt -q target  Quick scan with auth cookies"
    echo
    echo -e "${BOLD}Output:${RESET}  Results saved to ./<target>/"
    echo "  report.html       Interactive tree-map report (open in browser)"
    echo "  crawl/             Endpoints, params, JS files"
    echo "  scans/             Nmap, nuclei, vhost results"
    echo "  screenshots/       Full-page screenshots"
    echo "  subdomains/        Alive hosts, httpx fingerprints"
    echo
    echo -e "${BOLD}Pipeline:${RESET}"
    echo "  httpx → katana → feroxbuster → katana (re-crawl) → nuclei → ffuf → nmap → gowitness"
    echo "  New dirs from feroxbuster are re-crawled. Discovered vhosts are re-scanned."
    exit 1
}

log() { echo -e "${GREEN}[+]${RESET} $1"; }
warn() { echo -e "${YELLOW}[!]${RESET} $1"; }
err() { echo -e "${RED}[-]${RESET} $1"; }
info() { echo -e "${BLUE}[*]${RESET} $1"; }

check_tool() {
    if ! command -v "$1" &>/dev/null; then
        warn "$1 not found — skipping"
        return 1
    fi
    return 0
}

# Parse args
QUICK=false
DEEP=false
HEADERS=()

while getopts "qdhH:" opt; do
    case $opt in
        q) QUICK=true ;;
        d) DEEP=true ;;
        h) usage ;;
        H)
            if [ -f "$OPTARG" ]; then
                while IFS= read -r line; do
                    [ -n "$line" ] && [[ ! "$line" =~ ^# ]] && HEADERS+=("$line")
                done < "$OPTARG"
            else
                HEADERS+=("$OPTARG")
            fi
            ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

INPUT="$1"
[ -z "$INPUT" ] && usage

# Detect if input is a URL (direct target mode) or a domain (subdomain enum mode)
URL_MODE=false
if [[ "$INPUT" =~ ^https?:// ]]; then
    URL_MODE=true
    TARGET_URL="${INPUT%/}"
    DIRNAME=$(echo "$INPUT" | sed 's|https\?://||;s|[/:.]|_|g;s|_$||')
    # Extract hostname/IP for nmap (strip scheme, path, port)
    NMAP_TARGET=$(echo "$INPUT" | sed 's|https\?://||;s|[:/].*||')
else
    DOMAIN="$INPUT"
    DIRNAME="$DOMAIN"
fi

# Build tool-specific header args
HTTPX_HEADERS=()
KATANA_HEADERS=()
NUCLEI_HEADERS=()
GOWITNESS_HEADERS=()
FFUF_HEADERS=()
FEROX_HEADERS=()
for h in "${HEADERS[@]}"; do
    HTTPX_HEADERS+=(-H "$h")
    KATANA_HEADERS+=(-H "$h")
    NUCLEI_HEADERS+=(-H "$h")
    GOWITNESS_HEADERS+=(--chrome-header "$h")
    FFUF_HEADERS+=(-H "$h")
    FEROX_HEADERS+=(-H "$h")
done

banner
info "Target: $INPUT"
$QUICK && info "Quick mode enabled (skipping nuclei, vhosts)"
$DEEP && info "Deep mode enabled (subfinder + amass)"
$URL_MODE && info "URL mode: skipping subdomain enumeration"
[ ${#HEADERS[@]} -gt 0 ] && info "Custom headers: ${#HEADERS[@]} header(s) loaded"

# Setup directories
BASE="./$DIRNAME"
mkdir -p "$BASE"/{subdomains,screenshots,scans,crawl}

ALIVE="$BASE/subdomains/alive.txt"
HTTPX_FULL="$BASE/subdomains/httpx.txt"
SUBS_CLEAN="$BASE/subdomains/found.txt"
PHASE=1

if $URL_MODE; then
    echo "$TARGET_URL" > "$ALIVE"
    echo "$NMAP_TARGET" > "$SUBS_CLEAN"

    log "Phase $PHASE: Fingerprinting target"
    if check_tool httpx; then
        httpx -l "$ALIVE" -silent \
            -status-code -title -tech-detect -content-length \
            -follow-redirects \
            "${HTTPX_HEADERS[@]}" \
            -o "$HTTPX_FULL" 2>/dev/null
    fi
elif $QUICK; then
    echo "$DOMAIN" > "$SUBS_CLEAN"

    log "Phase $PHASE: Fingerprinting target (quick — skipping subdomain enum)"
    if check_tool httpx; then
        httpx -l "$SUBS_CLEAN" -silent \
            -status-code -title -tech-detect -content-length \
            -follow-redirects \
            "${HTTPX_HEADERS[@]}" \
            -o "$HTTPX_FULL" 2>/dev/null

        awk '{print $1}' "$HTTPX_FULL" > "$ALIVE"
    else
        cp "$SUBS_CLEAN" "$ALIVE"
    fi
else
    SUBS_RAW="$BASE/subdomains/raw.txt"
    > "$SUBS_RAW"

    if $DEEP; then
        log "Phase $PHASE: Subdomain Enumeration (deep)"
        if check_tool subfinder; then
            info "Running subfinder..."
            subfinder -d "$DOMAIN" -silent >> "$SUBS_RAW" &
        fi
        if check_tool assetfinder; then
            info "Running assetfinder..."
            assetfinder --subs-only "$DOMAIN" >> "$SUBS_RAW" &
        fi
        wait
        log "Subdomain enumeration complete"
    else
        log "Phase $PHASE: Fingerprinting target"
    fi

    ((PHASE++))
    log "Phase $PHASE: Deduplication"

    sort -u "$SUBS_RAW" | grep -F ".$DOMAIN" | grep -v '^\*' > "$SUBS_CLEAN"
    echo "$DOMAIN" >> "$SUBS_CLEAN"
    sort -u -o "$SUBS_CLEAN" "$SUBS_CLEAN"

    TOTAL=$(wc -l < "$SUBS_CLEAN")
    log "Found $TOTAL unique subdomains"

    if [ "$TOTAL" -eq 0 ]; then
        err "No subdomains found. Adding base domain only."
        echo "$DOMAIN" > "$SUBS_CLEAN"
    fi

    ((PHASE++))
    log "Phase $PHASE: Alive check & fingerprinting with httpx"

    if check_tool httpx; then
        httpx -l "$SUBS_CLEAN" -silent \
            -status-code -title -tech-detect -content-length \
            -follow-redirects \
            "${HTTPX_HEADERS[@]}" \
            -o "$HTTPX_FULL" 2>/dev/null

        awk '{print $1}' "$HTTPX_FULL" > "$ALIVE"

        ALIVE_COUNT=$(wc -l < "$ALIVE")
        log "$ALIVE_COUNT alive hosts found"
    else
        err "httpx not found — cannot continue alive check"
        cp "$SUBS_CLEAN" "$ALIVE"
    fi
fi

if [ ! -s "$ALIVE" ]; then
    err "No alive hosts. Nothing to do."
    exit 1
fi

# ============================================================
# Scanning phase (parallel)
# ============================================================
((PHASE++))
log "Phase $PHASE: Scanning (parallel)"

# --- Subdomain Takeover Check (domain mode only) ---
if ! $URL_MODE && check_tool subzy; then
    info "Checking subdomain takeover..."
    subzy run --targets "$SUBS_CLEAN" --hide_fails \
        > "$BASE/subdomains/takeover.txt" 2>/dev/null &
fi

# --- Screenshots (root/alive only — subfolder screenshots happen after crawl) ---
if check_tool gowitness; then
    info "Taking screenshots..."
    gowitness scan file -f "$ALIVE" \
        --screenshot-path "$BASE/screenshots" \
        --write-db=false \
        "${GOWITNESS_HEADERS[@]}" 2>/dev/null &
fi

# --- Port Scan (use hostname, not URL) ---
if check_tool nmap; then
    info "Port scanning..."
    if $QUICK; then
        nmap -T4 --top-ports 100 -oN "$BASE/scans/nmap_quick.txt" \
            -iL "$SUBS_CLEAN" > /dev/null 2>&1 &
    else
        nmap -T4 -sC -sV --top-ports 1000 -oN "$BASE/scans/nmap_full.txt" \
            -iL "$SUBS_CLEAN" > /dev/null 2>&1 &
    fi
fi

# --- Crawl with Katana ---
if check_tool katana; then
    info "Crawling with katana..."
    katana -list "$ALIVE" -silent \
        -depth 3 -js-crawl -known-files all \
        -fs fqdn -crawl-out-scope '.*logout.*' \
        "${KATANA_HEADERS[@]}" \
        -output "$BASE/crawl/katana_urls.txt" 2>/dev/null &
fi

# --- Nuclei ---
if ! $QUICK && check_tool nuclei; then
    info "Running nuclei..."
    nuclei -l "$ALIVE" -silent \
        -severity low,medium,high,critical \
        "${NUCLEI_HEADERS[@]}" \
        -o "$BASE/scans/nuclei.txt" 2>/dev/null &
fi

# --- Vhost Enumeration with ffuf ---
if ! $QUICK && check_tool ffuf; then
    if $URL_MODE; then
        VHOST_HOST=$(echo "$TARGET_URL" | sed 's|https\?://||;s|[:/].*||')
        VHOST_SCHEME=$(echo "$TARGET_URL" | grep -o '^https\?')
        VHOST_PORT=$(echo "$TARGET_URL" | sed -n 's|https\?://[^:/]*:\([0-9]*\).*|\1|p')
    else
        VHOST_HOST="$DOMAIN"
        VHOST_SCHEME="http"
        VHOST_PORT=""
    fi

    if $QUICK; then
        VHOST_WL="/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt"
    else
        VHOST_WL="/usr/share/seclists/Discovery/DNS/subdomains-top1million-20000.txt"
    fi

    if [ -f "$VHOST_WL" ]; then
        info "Vhost enumeration with ffuf..."
        VHOST_URL="${VHOST_SCHEME}://${VHOST_HOST}${VHOST_PORT:+:$VHOST_PORT}"
        ffuf -w "$VHOST_WL" \
            -u "$VHOST_URL" \
            -H "Host: FUZZ.${VHOST_HOST}" \
            -ac -mc all -fc 400 \
            "${FFUF_HEADERS[@]}" \
            -o "$BASE/scans/vhosts.json" \
            -of json 2>/dev/null &
    else
        warn "Vhost wordlist not found: $VHOST_WL"
    fi
fi

info "Waiting for scans to complete..."
wait

# --- Directory brute-force with feroxbuster ---
if check_tool feroxbuster; then
    ((PHASE++))
    log "Phase $PHASE: Directory brute-force with feroxbuster"
    FEROX_OUT="$BASE/scans/feroxbuster.txt"
    if $QUICK; then
        FEROX_WL="/usr/share/seclists/Discovery/Web-Content/raft-medium-directories.txt"
        FEROX_DEPTH=1
    else
        FEROX_WL="/usr/share/seclists/Discovery/Web-Content/raft-medium-directories.txt"
        FEROX_DEPTH=2
    fi
    if [ -f "$FEROX_WL" ]; then
        > "$FEROX_OUT"
        while IFS= read -r aurl; do
            info "Feroxbusting $aurl..."
            feroxbuster -u "$aurl" -w "$FEROX_WL" \
                -d "$FEROX_DEPTH" -t 50 --no-state --silent \
                -s 200,201,301,302,303,307,308,401,403,405 \
                -x php,html,txt,json,xml,cfg,bak,old \
                "${FEROX_HEADERS[@]}" \
                2>/dev/null | grep -v '^$' >> "$FEROX_OUT" &
        done < "$ALIVE"
        info "Waiting for feroxbuster..."
        wait
        FEROX_COUNT=$(wc -l < "$FEROX_OUT" 2>/dev/null || echo 0)
        if [ "$FEROX_COUNT" -gt 0 ]; then
            log "Feroxbuster found $FEROX_COUNT URLs"
            # Find new URLs not already discovered by katana
            FEROX_NEW="$BASE/scans/ferox_new.txt"
            sort -u "$FEROX_OUT" > "$FEROX_OUT.sorted"
            sort -u "$BASE/crawl/katana_urls.txt" 2>/dev/null > "$BASE/crawl/katana_urls.txt.sorted"
            comm -23 "$FEROX_OUT.sorted" "$BASE/crawl/katana_urls.txt.sorted" > "$FEROX_NEW"
            rm -f "$FEROX_OUT.sorted" "$BASE/crawl/katana_urls.txt.sorted"
            FEROX_NEW_COUNT=$(wc -l < "$FEROX_NEW" 2>/dev/null || echo 0)
            if [ "$FEROX_NEW_COUNT" -gt 0 ] && check_tool katana; then
                log "Re-crawling $FEROX_NEW_COUNT new URLs with katana..."
                katana -list "$FEROX_NEW" -silent \
                    -depth 2 -js-crawl \
                    -fs fqdn -crawl-out-scope '.*logout.*' \
                    "${KATANA_HEADERS[@]}" \
                    -output "$BASE/crawl/recrawl_urls.txt" 2>/dev/null
            fi
        fi
    else
        warn "Feroxbuster wordlist not found: $FEROX_WL"
    fi
fi

# --- Extract discovered vhosts ---
if [ -f "$BASE/scans/vhosts.json" ] && check_tool jq; then
    jq -r '.results[]?.input.FUZZ // empty' "$BASE/scans/vhosts.json" 2>/dev/null \
        | sort -u | while read -r vhost; do
            echo "${vhost}.${VHOST_HOST}"
        done > "$BASE/subdomains/vhosts.txt"
    VHOST_COUNT=$(wc -l < "$BASE/subdomains/vhosts.txt" 2>/dev/null || echo 0)
    if [ "$VHOST_COUNT" -gt 0 ]; then
        log "Found $VHOST_COUNT vhost(s)"
        cat "$BASE/subdomains/vhosts.txt"

        # Add discovered vhosts to alive list and scan them
        while read -r vh; do
            echo "${VHOST_SCHEME}://${vh}${VHOST_PORT:+:$VHOST_PORT}" >> "$ALIVE"
            echo "$vh" >> "$SUBS_CLEAN"
        done < "$BASE/subdomains/vhosts.txt"
        sort -u -o "$ALIVE" "$ALIVE"
        sort -u -o "$SUBS_CLEAN" "$SUBS_CLEAN"

        ((PHASE++))
        log "Phase $PHASE: Scanning discovered vhosts"

        VHOST_ALIVE="$BASE/subdomains/vhosts_alive.txt"
        while read -r vh; do
            echo "${VHOST_SCHEME}://${vh}${VHOST_PORT:+:$VHOST_PORT}"
        done < "$BASE/subdomains/vhosts.txt" > "$VHOST_ALIVE"

        if check_tool httpx; then
            httpx -l "$VHOST_ALIVE" -silent \
                -status-code -title -tech-detect -content-length \
                -follow-redirects \
                "${HTTPX_HEADERS[@]}" 2>/dev/null >> "$HTTPX_FULL" &
        fi
        if check_tool katana; then
            info "Crawling vhosts..."
            katana -list "$VHOST_ALIVE" -silent \
                -depth 3 -js-crawl -known-files all \
                -fs fqdn -crawl-out-scope '.*logout.*' \
                "${KATANA_HEADERS[@]}" \
                -output "$BASE/crawl/vhost_urls.txt" 2>/dev/null &
        fi
        if check_tool nuclei; then
            info "Scanning vhosts with nuclei..."
            nuclei -l "$VHOST_ALIVE" -silent \
                -severity low,medium,high,critical \
                "${NUCLEI_HEADERS[@]}" \
                >> "$BASE/scans/nuclei.txt" 2>/dev/null &
        fi
        if check_tool gowitness; then
            info "Screenshotting vhosts..."
            gowitness scan file -f "$VHOST_ALIVE" \
                --screenshot-path "$BASE/screenshots" \
                --write-db=false \
                "${GOWITNESS_HEADERS[@]}" 2>/dev/null &
        fi
        info "Waiting for vhost scans..."
        wait

        # Feroxbuster on vhosts
        if check_tool feroxbuster && [ -f "$FEROX_WL" ]; then
            info "Feroxbusting vhosts..."
            VHOST_FEROX="$BASE/scans/feroxbuster_vhosts.txt"
            > "$VHOST_FEROX"
            while IFS= read -r vurl; do
                info "Feroxbusting $vurl..."
                feroxbuster -u "$vurl" -w "$FEROX_WL" \
                    -d "$FEROX_DEPTH" -t 50 --no-state --silent \
                    -s 200,201,301,302,303,307,308,401,403,405 \
                    -x php,html,txt,json,xml,cfg,bak,old \
                    "${FEROX_HEADERS[@]}" \
                    2>/dev/null | grep -v '^$' >> "$VHOST_FEROX" &
            done < "$VHOST_ALIVE"
            wait
            cat "$VHOST_FEROX" >> "$FEROX_OUT"
            VHOST_FEROX_COUNT=$(wc -l < "$VHOST_FEROX" 2>/dev/null || echo 0)
            if [ "$VHOST_FEROX_COUNT" -gt 0 ]; then
                log "Feroxbuster found $VHOST_FEROX_COUNT vhost URLs"
                VHOST_FEROX_NEW="$BASE/scans/ferox_vhost_new.txt"
                sort -u "$VHOST_FEROX" > "$VHOST_FEROX.sorted"
                sort -u "$BASE/crawl/vhost_urls.txt" 2>/dev/null > "$BASE/crawl/vhost_urls.txt.sorted"
                comm -23 "$VHOST_FEROX.sorted" "$BASE/crawl/vhost_urls.txt.sorted" > "$VHOST_FEROX_NEW"
                rm -f "$VHOST_FEROX.sorted" "$BASE/crawl/vhost_urls.txt.sorted"
                VHOST_FEROX_NEW_COUNT=$(wc -l < "$VHOST_FEROX_NEW" 2>/dev/null || echo 0)
                if [ "$VHOST_FEROX_NEW_COUNT" -gt 0 ] && check_tool katana; then
                    log "Re-crawling $VHOST_FEROX_NEW_COUNT new vhost URLs with katana..."
                    katana -list "$VHOST_FEROX_NEW" -silent \
                        -depth 2 -js-crawl \
                        -fs fqdn -crawl-out-scope '.*logout.*' \
                        "${KATANA_HEADERS[@]}" \
                        >> "$BASE/crawl/recrawl_urls.txt" 2>/dev/null
                fi
            fi
        fi
    fi
fi

# Merge all source files into raw_endpoints.txt for post-processing
> "$BASE/crawl/raw_endpoints.txt"
for _src in katana_urls.txt recrawl_urls.txt vhost_urls.txt; do
    [ -s "$BASE/crawl/$_src" ] && cat "$BASE/crawl/$_src" >> "$BASE/crawl/raw_endpoints.txt"
done
[ -s "$BASE/scans/feroxbuster.txt" ] && cat "$BASE/scans/feroxbuster.txt" >> "$BASE/crawl/raw_endpoints.txt"
cat "$ALIVE" >> "$BASE/crawl/raw_endpoints.txt"

# ============================================================
# Post-processing: deduplicate crawl results
# ============================================================
if [ -s "$BASE/crawl/raw_endpoints.txt" ]; then
    ((PHASE++))
    log "Phase $PHASE: Processing crawl results"

    # Determine target scope for filtering (strip scheme + trailing slash)
    SCOPE_PATTERNS=()
    if $URL_MODE; then
        SCOPE_PATTERNS+=("$(echo "$TARGET_URL" | sed 's|/$||')")
        # Include discovered vhosts in scope
        if [ -s "$BASE/subdomains/vhosts.txt" ]; then
            while read -r vh; do
                SCOPE_PATTERNS+=("${vh}")
            done < "$BASE/subdomains/vhosts.txt"
        fi
    else
        SCOPE_PATTERNS+=("$DOMAIN")
    fi

    # Deduplicate endpoints, keep only in-scope (match any scope pattern)
    SCOPE_GREP=$(printf '%s\n' "${SCOPE_PATTERNS[@]}")
    grep -F -f <(echo "$SCOPE_GREP") "$BASE/crawl/raw_endpoints.txt" | sort -u > "$BASE/crawl/endpoints.txt"
    ENDPOINTS=$(wc -l < "$BASE/crawl/endpoints.txt")
    info "$ENDPOINTS unique in-scope endpoints"

    # Extract URLs with query parameters
    grep '?' "$BASE/crawl/endpoints.txt" | sort -u > "$BASE/crawl/params.txt"
    PARAMS=$(wc -l < "$BASE/crawl/params.txt")
    info "$PARAMS URLs with parameters found"

    # Extract unique parameter names
    grep -oP '[?&]\K[^=]+' "$BASE/crawl/params.txt" | sort -u > "$BASE/crawl/param_names.txt"

    # Extract JS files (in-scope only)
    grep -iE '\.js(\?|$)' "$BASE/crawl/endpoints.txt" | sort -u > "$BASE/crawl/js_files.txt"
    JS_COUNT=$(wc -l < "$BASE/crawl/js_files.txt")
    info "$JS_COUNT unique JS files found"

    # ============================================================
    # Screenshots of discovered paths (deduped, no params)
    # ============================================================
    if check_tool gowitness; then
        log "Taking screenshots of discovered pages..."
        # Strip query params, strip static assets, deduplicate
        sed 's|?.*||' "$BASE/crawl/endpoints.txt" \
            | grep -viE '\.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot|map)$' \
            | sort -u \
            > "$BASE/crawl/screenshot_urls.txt"

        SCREENSHOT_COUNT=$(wc -l < "$BASE/crawl/screenshot_urls.txt")
        info "Screenshotting $SCREENSHOT_COUNT unique pages..."

        gowitness scan file -f "$BASE/crawl/screenshot_urls.txt" \
            --screenshot-path "$BASE/screenshots" \
            --write-db=false \
            "${GOWITNESS_HEADERS[@]}" 2>/dev/null

        TAKEN=$(ls -1 "$BASE/screenshots/" 2>/dev/null | wc -l)
        log "$TAKEN screenshots saved"
    fi
fi

# ============================================================
# Final cleanup: deduplicate and sort all output files
# ============================================================
for f in \
    "$BASE/subdomains/alive.txt" \
    "$BASE/subdomains/found.txt" \
    "$BASE/subdomains/httpx.txt" \
    "$BASE/crawl/endpoints.txt" \
    "$BASE/crawl/params.txt" \
    "$BASE/crawl/param_names.txt" \
    "$BASE/crawl/js_files.txt" \
    "$BASE/crawl/screenshot_urls.txt" \
    "$BASE/scans/nuclei.txt"; do
    [ -s "$f" ] && sort -u -o "$f" "$f"
done

# ============================================================
# Summary
# ============================================================
echo ""
echo -e "${CYAN}═══════════════════════════════════════${RESET}"
echo -e "${CYAN}         BORING SUMMARY: $INPUT${RESET}"
echo -e "${CYAN}═══════════════════════════════════════${RESET}"

if ! $URL_MODE; then
    [ -f "$SUBS_CLEAN" ] && echo -e "  Subdomains:     $(wc -l < "$SUBS_CLEAN")"
fi
[ -f "$ALIVE" ] && echo -e "  Alive hosts:    $(wc -l < "$ALIVE")"
[ -f "$BASE/crawl/endpoints.txt" ] && echo -e "  Endpoints:      $(wc -l < "$BASE/crawl/endpoints.txt")"
[ -f "$BASE/crawl/params.txt" ] && echo -e "  Parameterized:  $(wc -l < "$BASE/crawl/params.txt")"
[ -f "$BASE/crawl/js_files.txt" ] && echo -e "  JS files:       $(wc -l < "$BASE/crawl/js_files.txt")"

SCREENSHOT_TOTAL=$(ls -1 "$BASE/screenshots/" 2>/dev/null | wc -l)
[ "$SCREENSHOT_TOTAL" -gt 0 ] && echo -e "  Screenshots:    $SCREENSHOT_TOTAL"

if [ -s "$BASE/scans/nuclei.txt" ]; then
    VULN_COUNT=$(wc -l < "$BASE/scans/nuclei.txt")
    echo -e "  ${RED}Nuclei findings: $VULN_COUNT${RESET}"
fi

if [ -s "$BASE/subdomains/takeover.txt" ]; then
    TAKEOVER_COUNT=$(grep -c "VULNERABLE" "$BASE/subdomains/takeover.txt" 2>/dev/null || true)
    TAKEOVER_COUNT=${TAKEOVER_COUNT:-0}
    [ "$TAKEOVER_COUNT" -gt 0 ] && echo -e "  ${RED}Takeover vulns:  $TAKEOVER_COUNT${RESET}"
fi

echo -e "${CYAN}═══════════════════════════════════════${RESET}"
echo -e "  Results saved to: ${BLUE}$BASE/${RESET}"
echo ""

# ============================================================
# Generate HTML Report — Interactive visual sitemap
# ============================================================
generate_report() {
    local BASE="$1"
    local TARGET="$2"
    local REPORT="$BASE/report.html"

    log "Generating interactive report..."

    python3 - "$BASE" "$TARGET" "$REPORT" << 'PYEOF'
import json, sys, os, subprocess, base64, re
from urllib.parse import urlparse, parse_qs
from datetime import datetime, timezone

BASE, TARGET, REPORT = sys.argv[1], sys.argv[2], sys.argv[3]
DATE = datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')

def read_lines(p):
    try: return [l.strip() for l in open(p) if l.strip()]
    except FileNotFoundError: return []

# Parse httpx
httpx = []
ansi_re = re.compile(r'\x1b\[[0-9;]*m')
