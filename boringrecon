    parts = re.findall(r'\[([^\]]*)\]', line)
    url = line.split()[0] if line.split() else ""
    httpx.append({"url":url, "status":parts[0] if parts else "",
        "length":parts[1] if len(parts)>1 else "", "title":parts[2] if len(parts)>2 else "",
        "tech":parts[3] if len(parts)>3 else ""})

# Parse nmap
ports = {}
nf = os.path.join(BASE,"scans/nmap_full.txt")
if not os.path.exists(nf): nf = os.path.join(BASE,"scans/nmap_quick.txt")
host = ""
for line in read_lines(nf):
    m = re.match(r'Nmap scan report for (.+)', line)
    if m: host = m.group(1); ports[host] = []
    m2 = re.match(r'(\d+/\w+)\s+(\w+)\s+(\S+)', line)
    if m2 and host: ports[host].append({"port":m2.group(1),"state":m2.group(2),"service":m2.group(3)})

# Parse nuclei
vulns = []
for line in read_lines(os.path.join(BASE, "scans/nuclei.txt")):
    line = ansi_re.sub('', line)
    parts = re.findall(r'\[([^\]]*)\]', line)
    url = line.split()[-1] if line.split() else ""
    vulns.append({"template":parts[0] if parts else "","severity":parts[2] if len(parts)>2 else "","url":url})

# Parse subdomain takeover results
takeovers = {}
for line in read_lines(os.path.join(BASE, "subdomains/takeover.txt")):
    if 'VULNERABLE' in line.upper():
        parts = line.split()
        for p in parts:
            if '.' in p and not p.startswith('['):
                takeovers[p.lower()] = line.strip()
                break

# Build D3 tree: {name, children[], urls[], path}
endpoints = read_lines(os.path.join(BASE, "crawl/endpoints.txt"))

