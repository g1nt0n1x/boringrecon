  svgEl.appendChild(svg);

  const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  g.id = 'zoom-group';
  svg.appendChild(g);

  // Links
  allLinks.forEach(l => {
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('class', 'link');
    g.appendChild(path);
    linkEls.push({ path, source: l.source, target: l.target });
  });

  // Nodes
  allNodes.forEach(n => {
    const ng = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    let cls = 'node';
    if (n._hasChildren) cls += ' has-children';
    if (n._hasParam) cls += ' has-param';
    if (n._hasVuln) cls += ' has-vuln';
    if (selectedNode && selectedNode._id === n._id) cls += ' selected';
    ng.setAttribute('class', cls);
